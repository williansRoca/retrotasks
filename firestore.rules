rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Items y perfil personales ──────────────────────────────
    // Cada usuario solo puede leer y escribir sus propios datos.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /items/{itemId} {
        allow read, delete: if request.auth != null && request.auth.uid == userId;
        allow create, update: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.title is string
          && request.resource.data.title.size() >= 1
          && request.resource.data.title.size() <= 500
          && request.resource.data.detail is string
          && request.resource.data.detail.size() <= 5000;
      }
    }

    // ── Tableros colaborativos ─────────────────────────────────
    // Cualquier usuario autenticado que conozca el código RT-XXXXX
    // puede leer y participar. El doc del tablero no se modifica
    // desde el cliente (el código de la app nunca lo actualiza).
    match /boards/{boardId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.creator is string
        && request.resource.data.creator.size() >= 1
        && request.resource.data.creator.size() <= 50;
      allow update, delete: if false;

      match /items/{itemId} {
        allow read, delete: if request.auth != null;
        allow create, update: if request.auth != null
          && request.resource.data.title is string
          && request.resource.data.title.size() >= 1
          && request.resource.data.title.size() <= 500
          && request.resource.data.detail is string
          && request.resource.data.detail.size() <= 5000;
      }
    }

    // ── Tokens FCM ─────────────────────────────────────────────
    // Solo el propio usuario puede leer y escribir sus tokens.
    match /fcmTokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
